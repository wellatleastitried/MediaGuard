# Real integration test env template for RunnersIntegrationTest
# Copy to .env.test and fill in local absolute paths that exist on your server.

# Jellyfin
jellyfin_enabled=false
jellyfin_config_path=/mnt/appdata/jellyfin/config

# Radarr
radarr_enabled=false
radarr_path=/mnt/appdata/radarr

# Sonarr
sonarr_enabled=false
sonarr_path=/mnt/appdata/sonarr

# Prowlarr
prowlarr_enabled=false
prowlarr_path=/mnt/appdata/prowlarr

# Tdarr
tdarr_enabled=false
tdarr_path=/mnt/appdata/tdarr

# qBittorrent
qbittorrent_enabled=false
qbittorrent_path=/mnt/appdata/qbittorrent
qbittorrent_graveyard_path=/mnt/media/graveyard
