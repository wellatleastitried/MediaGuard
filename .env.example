# Host port bindings
SERVER_PORT=38471
CLIENT_PORT=8081

# Host storage locations used by docker-compose volumes
BACKUP_ROOT_HOST_PATH=./data/server/backups
CLIENT_DOWNLOADS_HOST_PATH=./data/client/downloads
CLIENT_STATE_HOST_PATH=./data/client

# Client behavior
MEDIAGUARD_SERVER_URL=http://mediaguard-server:8080
CLIENT_PICKUP_INTERVAL=PT12H

# Backup behavior
MEDIAGUARD_BACKUP_INTERVAL=PT12H
MEDIAGUARD_BACKUP_ROOT=/var/lib/mediaguard/backups
MEDIAGUARD_RETENTION_COUNT=10

# Host source paths mounted into server container
JELLYFIN_ENABLED=true
JELLYFIN_PATH=/mnt/appdata/jellyfin

RADARR_ENABLED=true
RADARR_PATH=/mnt/appdata/radarr

SONARR_ENABLED=true
SONARR_PATH=/mnt/appdata/sonarr

PROWLARR_ENABLED=true
PROWLARR_PATH=/mnt/appdata/prowlarr

TDARR_ENABLED=true
TDARR_PATH=/mnt/appdata/tdarr

QBITTORRENT_ENABLED=true
QBITTORRENT_PATH=/mnt/appdata/qbittorrent
QBITTORRENT_GRAVEYARD_PATH=/mnt/media/graveyard
